{
  "name": "backend",
  "version": "1.0.0",
  "description": "StoryCast 🎧 is your new podcast buddy! 🌟 Made with React Native, Node.js, and MongoDB, it brings you endless podcasts on any topic. 🎶 Dive into mysteries, discover cooking tips, and explore new worlds - all with StoryCast! 📱",
  "main": "index.js",
  "scripts": {
    "start": "tsnd --respawn -r tsconfig-paths/register --pretty --transpile-only src/server.ts",
    "build": "tsc && tsc-alias"
  },
  "keywords": [
    "Podcast"
  ],
  "author": "Himanshu Chuchra",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.4.3",
    "nodemailer": "^6.9.14",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/dotenv": "^8.2.0",
    "@types/express": "^4.17.21",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^20.14.8",
    "@types/nodemailer": "^6.4.15",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.2"
  }
}
